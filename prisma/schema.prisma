generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Bookmark {
  id           Int      @id @default(autoincrement())
  storyId      Int      @unique
  title        String
  url          String?
  author       String
  points       Int      @default(0)
  commentCount Int      @default(0)
  createdAt    DateTime @default(now())
}

model Summary {
  id        Int      @id @default(autoincrement())
  storyId   Int      @unique
  keyPoints String[]
  sentiment String
  summary   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}